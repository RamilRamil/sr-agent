# ── LLM APIs ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Blockchain ────────────────────────────────────────────────────────────
ALCHEMY_API_KEY=
TENDERLY_API_KEY=

# ── Memory integrity ──────────────────────────────────────────────────────
# Generate once: python -c "import secrets; print(secrets.token_hex(32))"
# Never commit the actual value. Rotation = all existing records invalidated.
SR_SECRET_KEY=

# ── Storage roots ─────────────────────────────────────────────────────────
SR_MEMORY_ROOT=./memory
SR_KNOWLEDGE_ROOT=./knowledge
SR_CONFIRMATIONS_ROOT=./confirmations
SR_RELAY_ROOT=./relay

# SmartGraphical engine (feature 002) — path to the SmartGraphical checkout.
# Empty disables the engine; the interpreter defaults to <root>/.venv/bin/python.
SR_SMARTGRAPHICAL_ROOT=

# ── Model routing ─────────────────────────────────────────────────────────
SR_STAGE1_MODEL=claude-opus-4-8
SR_STAGE2_MODEL=sr-stage2      # fine-tuned Qwen3-4B via Ollama; fallback: qwen3:4b
SR_STAGE3_MODEL=claude-opus-4-8
SR_POC_MODEL=qwen3-coder        # local via Ollama

# ── Langfuse observability ────────────────────────────────────────────────
# Leave empty to disable tracing (langfuse_enabled=False in config).
# Must match LANGFUSE_INIT_PROJECT_PUBLIC_KEY/SECRET_KEY below — those are
# what actually provision the project+keys on the server at first boot.
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=http://localhost:3000

# ── Langfuse internal (docker-compose only) ───────────────────────────────
LANGFUSE_POSTGRES_PASSWORD=langfuse
LANGFUSE_NEXTAUTH_SECRET=changeme-generate-random
LANGFUSE_SALT=changeme-generate-random
# Required by the langfuse:2 image; generate via: openssl rand -hex 32
LANGFUSE_ENCRYPTION_KEY=
LANGFUSE_CLICKHOUSE_USER=clickhouse
LANGFUSE_CLICKHOUSE_PASSWORD=changeme-generate-random
LANGFUSE_REDIS_PASSWORD=changeme-generate-random
LANGFUSE_MINIO_ROOT_USER=minio
LANGFUSE_MINIO_ROOT_PASSWORD=changeme-generate-random

# ── Langfuse headless init (docker-compose only) ──────────────────────────
# Set once, before the first `docker-compose up langfuse`: the server
# auto-creates this org/project/user/API-keys on boot with no browser step.
# No-op on every later boot once they already exist. See:
# https://langfuse.com/self-hosting/administration/headless-initialization
LANGFUSE_INIT_ORG_ID=sr-agent-org
LANGFUSE_INIT_ORG_NAME=SR Agent
LANGFUSE_INIT_PROJECT_ID=sr-agent
LANGFUSE_INIT_PROJECT_NAME=sr-agent
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=
LANGFUSE_INIT_PROJECT_SECRET_KEY=
LANGFUSE_INIT_USER_EMAIL=admin@sr-agent.local
LANGFUSE_INIT_USER_NAME=SR Agent Admin
LANGFUSE_INIT_USER_PASSWORD=
