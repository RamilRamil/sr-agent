# ── LLM APIs ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Blockchain ────────────────────────────────────────────────────────────
ALCHEMY_API_KEY=
TENDERLY_API_KEY=

# ── Memory integrity ──────────────────────────────────────────────────────
# Generate once: python -c "import secrets; print(secrets.token_hex(32))"
# Never commit the actual value. Rotation = all existing records invalidated.
SR_SECRET_KEY=

# ── Storage roots ─────────────────────────────────────────────────────────
SR_MEMORY_ROOT=./memory
SR_KNOWLEDGE_ROOT=./knowledge

# ── Model routing ─────────────────────────────────────────────────────────
SR_STAGE1_MODEL=claude-opus-4-8
SR_STAGE2_MODEL=sr-stage2      # fine-tuned Qwen3-4B via Ollama; fallback: qwen3:4b
SR_STAGE3_MODEL=claude-opus-4-8
SR_POC_MODEL=qwen3-coder        # local via Ollama

# ── Langfuse observability ────────────────────────────────────────────────
# Leave empty to disable tracing (langfuse_enabled=False in config)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=http://localhost:3000

# ── Langfuse internal (docker-compose only) ───────────────────────────────
LANGFUSE_POSTGRES_PASSWORD=langfuse
LANGFUSE_NEXTAUTH_SECRET=changeme-generate-random
LANGFUSE_SALT=changeme-generate-random
